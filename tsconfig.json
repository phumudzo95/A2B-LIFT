{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "paths": {
      "@mobile-core": [
        "./packages/mobile-core/src/index.ts"
      ],
      "@mobile-core/*": [
        "./packages/mobile-core/src/*"
      ],
      "@mobile-ui": [
        "./packages/mobile-ui/src/index.ts"
      ],
      "@mobile-ui/*": [
        "./packages/mobile-ui/src/*"
      ],
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "attached_assets",
    "server_dist"
  ]
}
