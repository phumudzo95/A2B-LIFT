{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://api.a2blift.com",
        "EXPO_PUBLIC_REFERRAL_BASE_URL": "https://a2blift.com",
        "EXPO_PUBLIC_SUPABASE_URL": "https://zzwkieiktbhptvgsqerd.supabase.co"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_EAS_OWNER": "pamol-digital",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "f282a582-7512-48d6-b563-13aa571d9115",
        "EXPO_PUBLIC_DOMAIN": "https://api.a2blift.com",
        "EXPO_PUBLIC_REFERRAL_BASE_URL": "https://a2blift.com",
        "EXPO_PUBLIC_SUPABASE_URL": "https://zzwkieiktbhptvgsqerd.supabase.co"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://api.a2blift.com",
        "EXPO_PUBLIC_REFERRAL_BASE_URL": "https://a2blift.com",
        "EXPO_PUBLIC_SUPABASE_URL": "https://zzwkieiktbhptvgsqerd.supabase.co"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "kidcornerza@gmail.com"
      }
    }
  }
}