entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[env]
PORT = "5000"

[agent]
stack = "EXPO"
expertMode = true
integrations = ["javascript_database:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Git Push"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 1; npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8080/tcp 2>/dev/null; sleep 1; EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=https://$RAILWAY_PUBLIC_DOMAIN EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=$GOOGLE_API_KEY EXPO_PUBLIC_SUPABASE_URL=$SUPABASE_URL EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=$PAYSTACK_PUBLIC_KEY ./node_modules/.bin/expo start --port 8080"

[[workflows.workflow]]
name = "Git Push"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "rm -f .git/index.lock && git config user.email 'a2blift@deploy.com' && git config user.name 'A2B Lift' && git remote set-url origin https://$GITHUB_TOKEN@github.com/phumudzo95/A2B-LIFT.git && git add -A && git diff --cached --quiet && echo 'Nothing to commit' || git commit -m 'fix: wire all backends to Supabase DB' && git push origin main 2>&1"

[userenv]

[userenv.shared]
JWT_SECRET = "918af73337fa8332dc0e0769b6b9babab0e1d090a26ffcef2d7029ec9b5ec1ebdebd63ab337c1f3005cb45f0c00d58f4a6bc6f80087bd2066c69a48264c4ecf1"
SUPABASE_DB_URL = "postgresql://postgres.zzwkieiktbhptvgsqerd:A2brt89%400kk@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
